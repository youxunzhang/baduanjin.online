page {
  background: linear-gradient(180deg, #6177f3 0%, #7b4bbb 100%);
}

.sudoku-page {
  padding: 24rpx;
  color: #eef2ff;
  min-height: 100vh;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 20rpx;
}

.hero-title {
  text-align: center;
  font-size: 52rpx;
  line-height: 1.2;
  font-weight: 700;
}

.difficulty-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 40rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  color: rgba(255, 255, 255, 0.88);
  font-size: 34rpx;
  border-radius: 32rpx;
  font-weight: 600;
}

.tab-item.active {
  background: #fff;
  color: #5f6fd8;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.meta-pill {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.meta-pill.error {
  text-align: right;
}

.meta-pill.error.danger {
  background: rgba(238, 75, 100, 0.26);
  color: #ffe8ec;
}

.action-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 18rpx;
  border: none;
  background: rgba(255, 255, 255, 0.92);
  color: #3c4ec6;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin: 0;
  padding: 0 20rpx;
}

.action-btn::after {
  border: none;
}

.feature-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.chip {
  background: rgba(255, 255, 255, 0.2);
  color: #eef2ff;
  border-radius: 999rpx;
  padding: 10rpx 20rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.chip.active {
  background: rgba(255, 255, 255, 0.35);
}

.status-box {
  margin: 14rpx 0;
  background: rgba(255, 255, 255, 0.24);
  border-radius: 18rpx;
  padding: 16rpx 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #f7f9ff;
}

.grid-wrap {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(10, 22, 80, 0.2);
}

.grid {
  display: grid;
  grid-template-columns: repeat(9, 1fr);
}

.cell {
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border: 1rpx solid #d6dbe8;
  font-size: 40rpx;
  font-weight: 700;
  color: #566fd9;
  background: #fff;
}

.cell.shade {
  background: #f6f8ff;
}

.cell.given {
  font-weight: 800;
}

.cell.conflict {
  color: #cf3f59;
  background: #ffe7ec;
}

.cell.selected {
  box-shadow: inset 0 0 0 4rpx #6177f3;
}

.number-pad {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
}

.number-btn {
  height: 80rpx;
  border-radius: 14rpx;
  border: none;
  background: rgba(255, 255, 255, 0.95);
  color: #536ad5;
  font-size: 38rpx;
  font-weight: 700;
  margin: 0;
  padding: 0;
}

.number-btn::after {
  border: none;
}

.number-btn.erase {
  background: rgba(246, 247, 255, 0.95);
}

.sudoku-page.large-text .hero-title {
  font-size: 58rpx;
}

.sudoku-page.large-text .tab-item,
.sudoku-page.large-text .meta-pill,
.sudoku-page.large-text .action-btn,
.sudoku-page.large-text .status-box,
.sudoku-page.large-text .cell,
.sudoku-page.large-text .number-btn {
  font-size: 44rpx;
}

.sudoku-page.high-contrast {
  background: #00114d;
}

.sudoku-page.high-contrast .difficulty-tabs,
.sudoku-page.high-contrast .meta-pill,
.sudoku-page.high-contrast .chip,
.sudoku-page.high-contrast .status-box {
  background: rgba(0, 0, 0, 0.35);
  color: #fff;
}

.sudoku-page.high-contrast .tab-item.active,
.sudoku-page.high-contrast .action-btn,
.sudoku-page.high-contrast .number-btn {
  background: #fff;
  color: #000;
}

.sudoku-page.high-contrast .cell {
  color: #000;
  border-color: #333;
}

.action-row.big .action-btn {
  height: 96rpx;
}

.difficulty-tabs.big .tab-item {
  padding: 20rpx 0;
}

.number-pad.big .number-btn {
  height: 96rpx;
}
